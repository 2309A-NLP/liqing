# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Redis
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_PASSWORD=123456
SESSION_TTL=86400
MEMORY_MAX_ITEMS=5000
MEMORY_IMPORTANCE_THRESHOLD=0.45

# Milvus
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
MILVUS_USER=
MILVUS_PASSWORD=
MILVUS_DATABASE=default
MILVUS_COLLECTION=pdf_chunks
MILVUS_MEMORY_COLLECTION=rag_long_term_memory

# Models
EMBED_MODEL_PATH=D:\models\bge-m3
RERANK_MODEL_PATH=D:\models\bge-reranker-base

